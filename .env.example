#
# Minimal env for local dev / docker-compose.
#
# Integration settings (Home Assistant, MQTT, Z-Wave JS, Zigbee2MQTT, Frigate)
# and notification providers are configured via the Settings UI and stored in
# the database with encryption at rest (ADR 0079).
#
# Values shown in commented-out lines are the defaults baked into the code —
# uncomment and change them only if you need to override.
#

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
SECRET_KEY=change-me
DEBUG=True
# TIME_ZONE=UTC
# API_RESPONSE_ENVELOPE_ENABLED=True
# ENV_FILE=                                  # Explicit .env path; auto-detected if unset

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Hosts & CORS
# ---------------------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1
# ALLOW_ALL_HOSTS=False                      # When True, overrides ALLOWED_HOSTS with "*"

# Cross-origin SPA dev (backend :5427, frontend :5428 or Vite :5173)
# When DEBUG=True and CSRF_TRUSTED_ORIGINS is empty, the backend auto-trusts
# common dev origins for hosts listed in ALLOWED_HOSTS.
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:5428,http://localhost:5173
# CORS_ALLOW_ALL_ORIGINS=False

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# - docker-compose: keep `DATABASE_URL` set (Postgres)
# - no DB config: omit `DATABASE_URL` to fall back to SQLite at `backend/db.sqlite3`
POSTGRES_DB=alarm_db
POSTGRES_USER=alarm
POSTGRES_PASSWORD=alarm                      # Change in production
DATABASE_URL=postgresql://alarm:alarm@db:5432/alarm_db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Per-module overrides default to LOG_LEVEL when unset.
# HA_LOG_LEVEL=INFO
# ZWAVEJS_LOG_LEVEL=INFO
# CONTROL_PANELS_LOG_LEVEL=INFO
# WS_LOG_LEVEL=INFO

# Log viewer (ADR 0072) — in-memory circular buffer exposed over WebSocket
# LOG_VIEWER_CAPTURE_LEVEL=DEBUG
# LOG_VIEWER_BROADCAST_LEVEL=WARNING
# LOG_VIEWER_BUFFER_SIZE=500

# ---------------------------------------------------------------------------
# Scheduler (APScheduler)
# ---------------------------------------------------------------------------
# SCHEDULER_ENABLED=True
# SCHEDULER_LEADER_LOCK_ENABLED=False        # Enable for multi-instance deployments
# SCHEDULER_LEADER_LOCK_ID=4242001
# SCHEDULER_INSTANCE_ID=                     # Auto-generated if empty
# SCHEDULER_FAILURE_EVENT_THRESHOLD=3
# SCHEDULER_SLOW_RUN_THRESHOLD_SECONDS=2.0
# SCHEDULER_RUN_HISTORY_RETENTION_DAYS=30
# SCHEDULER_RUN_HISTORY_MAX_PER_TASK=500
# SCHEDULER_TASK_OVERRIDES={}                # JSON, e.g. {"task_name":{"run_interval_minutes":60}}

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
# NOTIFICATIONS_DELIVERY_LOCK_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Encryption (ADR 0079)
# ---------------------------------------------------------------------------
# Fernet key for encrypting secrets at rest. If not set, a key is auto-
# generated on first boot and persisted in DATA_DIR/.encryption_key.
# Generate one explicitly with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SETTINGS_ENCRYPTION_KEY=
# DATA_DIR=/data

# ---------------------------------------------------------------------------
# Testing flags (skip integration tests unless explicitly enabled)
# ---------------------------------------------------------------------------
# ALLOW_HOME_ASSISTANT_IN_TESTS=False
# ALLOW_ZWAVEJS_IN_TESTS=False

# ---------------------------------------------------------------------------
# Frontend (Vite) — build-time, inlined into the bundle
# ---------------------------------------------------------------------------
# VITE_API_URL=                              # Runtime API base URL; empty = same origin
# VITE_WS_URL=                               # Defaults to VITE_API_URL when unset
# VITE_API_PROXY_TARGET=http://backend:8000  # Vite dev server proxy (docker-compose default)

# ---------------------------------------------------------------------------
# Docker runtime (volume ownership mapping)
# ---------------------------------------------------------------------------
# LOCAL_UID=1000
# LOCAL_GID=1000
