#
# Minimal env for local dev / docker-compose.
#
# NOTE: Integration connection settings (Home Assistant, MQTT, Z-Wave JS, etc)
# are configured in the UI and stored in the active Alarm Settings Profile.
# `SETTINGS_ENCRYPTION_KEY` is required to persist secrets (tokens/passwords).
#

# Django
SECRET_KEY=change-me
SETTINGS_ENCRYPTION_KEY=change-me
DEBUG=True
API_RESPONSE_ENVELOPE_ENABLED=True
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1

# Cross-origin SPA dev (backend :5427, frontend :5428 or Vite :5173)
# When DEBUG=True and CSRF_TRUSTED_ORIGINS is empty, the backend auto-trusts
# common dev origins for hosts listed in ALLOWED_HOSTS.
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:5428,http://localhost:5173

# Database
# - Leave DB_* empty to fall back to SQLite at `backend/db.sqlite3`
# - For docker-compose Postgres defaults, keep DB_* as shown
# - For MySQL, set DB_HOST to your mysql host/service (e.g. `mysql`)
DB_DATABASE=alarm_db
DB_USERNAME=alarm
DB_PASSWORD=alarm
DB_HOST=db
# Optional connection hint
# DB_PORT=5432

# Optional log overrides (defaults to LOG_LEVEL)
# ZWAVEJS_LOG_LEVEL=INFO
# CONTROL_PANELS_LOG_LEVEL=INFO
# HA_LOG_LEVEL=INFO
# WS_LOG_LEVEL=INFO
